{
  "name": "telegram-bot-starter",
  "version": "1.0.0",
  "description": "Production-ready Telegram bot template with CI/CD and one-click deployment",
  "main": "src/index.js",
  "private": true,
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "preflight": "npm run build && npm test",
    "build": "node scripts/check-syntax.js",
    "lint": "eslint src/",
    "test": "jest --verbose --coverage",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "grammy": "^1.44.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "license-checker": "^25.0.1"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 95,
        "branches": 85,
        "functions": 90,
        "lines": 95
      }
    },
    "coverageReporters": [
      "text",
      "text-summary",
      "json-summary"
    ]
  },
  "engines": {
    "node": ">=22"
  }
}
