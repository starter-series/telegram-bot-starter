{
  "name": "telegram-bot-starter",
  "version": "1.0.0",
  "description": "Production-ready Telegram bot template with CI/CD and one-click deployment",
  "main": "src/index.js",
  "private": true,
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "lint": "eslint src/",
    "test": "jest --verbose --passWithNoTests",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "grammy": "^1.42.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "license-checker": "^25.0.1"
  },
  "jest": {
    "coverageThreshold": {
      "global": {
        "statements": 50,
        "branches": 50,
        "functions": 50,
        "lines": 50
      }
    }
  },
  "engines": {
    "node": ">=20"
  }
}
