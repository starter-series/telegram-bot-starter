# Required
BOT_TOKEN=your-bot-token-from-botfather

# Optional: set for webhook mode (leave empty for long polling)
# WEBHOOK_URL=https://your-domain.com/webhook
# WEBHOOK_SECRET=                          # required if WEBHOOK_URL is set;
                                           # generate with: openssl rand -hex 32
# PORT=3000

# Optional: port for the /health endpoint (polling mode only — webhook mode
# mounts /health on the webhook server's PORT instead).
HEALTH_PORT=3000
